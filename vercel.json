{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/indexnow-submit/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/indexnow-key.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/deploy-hook",
      "destination": "/api/indexnow-submit"
    }
  ]
}